#!/usr/bin/env bash
# 🌿 tryhackme — study mode activator

G='\033[38;2;123;201;111m'
C='\033[38;2;245;243;231m'
D='\033[38;2;150;150;170m'
RESET='\033[0m'

# ── Subcommand: update ────────────────────────────────────────────────────────
if [[ "$1" == "update" ]]; then
    MSG="${*:2}"
    if [[ -z "$MSG" ]]; then
        echo -e "${G}🌿${RESET} Usage: ${C}tryhackme update \"your commit message\"${RESET}"
        exit 1
    fi

    NOTES_DIR="$HOME/Documents/cybernotes"

    if [[ ! -d "$NOTES_DIR/.git" ]]; then
        echo -e "${G}🌿${RESET} ${C}cybernotes not found at $NOTES_DIR${RESET}"
        exit 1
    fi

    echo -e "${G}🌿${RESET} ${C}Syncing cybernotes...${RESET}"
    cd "$NOTES_DIR" || exit 1
    git add -A
    git commit -m "$MSG" 2>&1 | grep -v "^$"
    git push 2>&1 | tail -3
    echo -e "${G}🌿${RESET} ${C}Done. Very professional.${RESET}"
    exit 0
fi

# ── Normal launch: open Firefox + Obsidian on workspace N ────────────────────
WORKSPACE="${1:-2}"

if ! [[ "$WORKSPACE" =~ ^[0-9]+$ ]]; then
    echo -e "${G}🌿${RESET} Usage: ${C}tryhackme [workspace]${RESET}  ${D}(default: 2)${RESET}"
    echo -e "       ${C}tryhackme update \"message\"${RESET}"
    exit 1
fi

echo -e "${G}🌿${RESET} ${C}Study mode — workspace ${WORKSPACE}${RESET}"

# Switch desktop (KWin uses 1-indexed)
qdbus6 org.kde.KWin /KWin org.kde.KWin.setCurrentDesktop "$WORKSPACE" &>/dev/null

sleep 0.4

# Launch fully detached so the terminal is freed immediately
setsid firefox "https://tryhackme.com/dashboard" &>/dev/null &
disown

sleep 0.4

setsid obsidian "obsidian://open?vault=cybernotes" &>/dev/null &
disown

echo -e "${G}🌿${RESET} ${D}apps launched. go hack something.${RESET}"
